    (return__001_ (r: bool) {(r <-> (t = Empty))})
= destruct_is_empty1 {t}
  (-> return__001_ {true: bool} ) 
  (fun (l: (tree int)) (x: int) (r: (tree int)) ->
    return__001_ {false: bool} ) 

type elt = int

predicate le (x: int) (y: int) = x <= y

predicate le_root (e: elt) (t: tree elt) =
  match t with
  | Empty  -> true
  | Node _ x _ -> le e x
  end

predicate heap (t: tree elt) =
  match t with
  | Empty  -> true
  | Node l x r -> (le_root x l) && (heap l) && (le_root x r) && (heap r)
  end

function minimum (t: tree elt) : elt

axiom minimum_def: forall l, x, r. (minimum (Node l x r)) = x

predicate is_minimum (x: elt) (t: tree elt) =
  (mem x t) && (forall e. (mem e t) -> (le x e))

lemma is_min:
  forall t : tree elt.
    (heap t) -> ((size t) > 0) -> (is_minimum (minimum t) t)

