let halt = any
let fail { false } = any
let if (b: bool) (then {b}) (else {not b}) = any

type tree 'a = 
    | Empty
    | Node (tree 'a) 'a (tree 'a)

function size (t: tree 'a) : int =
  match t with
  | Empty  -> 0
  | Node l _ r -> (1 + (size l)) + (size r)
  end

lemma size_nonneg: forall t : tree 'a. (size t) >= 0

lemma size_empty: forall t : tree 'a. (0 = (size t)) <-> (t = Empty)

function occ (v: 'a) (t: tree 'a) : int =
  match t with
  | Empty  -> 0
  | Node l x r -> ((occ v l) + (occ v r)) + (if (x = v) then 1
                                             else 0)
  end

lemma occ_nonneg: forall x : 'a, t : tree 'a. (occ x t) >= 0

predicate mem (v: 'a) (t: tree 'a) = 0 < (occ v t)

let destruct_is_empty1 (t: (tree int))
   (empty {(t = Empty)})
   (node (l: (tree int)) (x: int) (r: (tree int)) {(t = (Node l x r))})
= any

